FROM python:3.11-slim
WORKDIR /app
# Install system dependencies for MySQL and networking
RUN apt-get update && apt-get install -y --no-install-recommends default-libmysqlclient-dev build-essential && apt-get clean && rm -rf /var/lib/apt/lists/*
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && pip install --no-cache-dir -r requirements.txt
COPY . .

EXPOSE 5000
USER nobody
CMD ["python", "run.py"]